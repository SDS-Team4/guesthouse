{
  "name": "guesthouse-web-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": "24.x",
    "pnpm": "9.x"
  },
  "scripts": {
    "dev:guest-web": "pnpm --filter guest-web dev",
    "dev:ops-web": "pnpm --filter ops-web dev",
    "build:web": "pnpm --filter guest-web build && pnpm --filter ops-web build"
  }
}
