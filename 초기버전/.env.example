# Shared app baseline
SPRING_PROFILES_ACTIVE=local
APP_TIMEZONE=Asia/Seoul
APP_LOCALE=ko-KR
APP_ENCODING=UTF-8

# Server / runtime
SERVER_PORT=8080

# Database
MYSQL_DATABASE=guesthouse_demo_a
DB_URL=jdbc:mysql://localhost:3306/guesthouse_demo_a?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=guesthouse
DB_PASSWORD=guesthouse

# Redis / session
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SESSION_NAMESPACE=guesthouse:demo-a:session

# AWS SES (optional)
SES_REGION=ap-northeast-2

# Solapi (optional)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
