# Spring profile / server
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Database
DB_URL=jdbc:mysql://localhost:3306/guesthouse?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=guesthouse
DB_PASSWORD=guesthouse

# Redis (optional in local if feature not used)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS SES (optional)
SES_REGION=ap-northeast-2

# Solapi (optional)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
