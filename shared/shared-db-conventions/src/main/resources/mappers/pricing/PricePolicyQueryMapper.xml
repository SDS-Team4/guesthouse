<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.guesthouse.shared.db.pricing.mapper.PricePolicyQueryMapper">

    <resultMap id="OpsPricingAccommodationOptionRecordMap" type="com.guesthouse.shared.db.pricing.model.OpsPricingAccommodationOptionRecord">
        <id property="accommodationId" column="accommodation_id"/>
        <result property="accommodationName" column="accommodation_name"/>
        <result property="region" column="region"/>
    </resultMap>

    <resultMap id="OpsPricingRoomTypeOptionRecordMap" type="com.guesthouse.shared.db.pricing.model.OpsPricingRoomTypeOptionRecord">
        <id property="roomTypeId" column="room_type_id"/>
        <result property="accommodationId" column="accommodation_id"/>
        <result property="roomTypeName" column="room_type_name"/>
        <result property="basePrice" column="base_price"/>
    </resultMap>

    <resultMap id="OpsPricePolicyRecordMap" type="com.guesthouse.shared.db.pricing.model.OpsPricePolicyRecord">
        <id property="policyId" column="policy_id"/>
        <result property="accommodationId" column="accommodation_id"/>
        <result property="accommodationName" column="accommodation_name"/>
        <result property="roomTypeId" column="room_type_id"/>
        <result property="roomTypeName" column="room_type_name"/>
        <result property="policyName" column="policy_name"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="deltaAmount" column="delta_amount"/>
        <result property="dayOfWeekMask" column="day_of_week_mask"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="OpsPricingRoomTypeTargetRecordMap" type="com.guesthouse.shared.db.pricing.model.OpsPricingRoomTypeTargetRecord">
        <id property="roomTypeId" column="room_type_id"/>
        <result property="accommodationId" column="accommodation_id"/>
        <result property="accommodationName" column="accommodation_name"/>
        <result property="roomTypeName" column="room_type_name"/>
        <result property="basePrice" column="base_price"/>
        <result property="roomTypeStatus" column="room_type_status"/>
        <result property="hostUserId" column="host_user_id"/>
    </resultMap>

    <resultMap id="OpsPricePolicyMutationTargetRecordMap" type="com.guesthouse.shared.db.pricing.model.OpsPricePolicyMutationTargetRecord">
        <id property="policyId" column="policy_id"/>
        <result property="accommodationId" column="accommodation_id"/>
        <result property="accommodationName" column="accommodation_name"/>
        <result property="roomTypeId" column="room_type_id"/>
        <result property="roomTypeName" column="room_type_name"/>
        <result property="hostUserId" column="host_user_id"/>
        <result property="policyName" column="policy_name"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="deltaAmount" column="delta_amount"/>
        <result property="dayOfWeekMask" column="day_of_week_mask"/>
        <result property="status" column="status"/>
    </resultMap>

    <resultMap id="ActivePricePolicyRecordMap" type="com.guesthouse.shared.db.reservation.model.ActivePricePolicyRecord">
        <id property="policyId" column="policy_id"/>
        <result property="roomTypeId" column="room_type_id"/>
        <result property="roomTypeName" column="room_type_name"/>
        <result property="policyName" column="policy_name"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="deltaAmount" column="delta_amount"/>
        <result property="dayOfWeekMask" column="day_of_week_mask"/>
    </resultMap>

    <select id="findAccessibleAccommodations" resultMap="OpsPricingAccommodationOptionRecordMap">
        SELECT
            a.accommodation_id,
            a.name AS accommodation_name,
            a.region
        FROM accommodations a
        WHERE a.status = 'ACTIVE'
          AND (#{isAdmin} = TRUE OR a.host_user_id = #{hostUserId})
        ORDER BY a.name ASC, a.accommodation_id ASC
    </select>

    <select id="findActiveRoomTypesByAccommodationId" resultMap="OpsPricingRoomTypeOptionRecordMap">
        SELECT
            rt.room_type_id,
            rt.accommodation_id,
            rt.name AS room_type_name,
            rt.base_price
        FROM room_types rt
        JOIN accommodations a
            ON a.accommodation_id = rt.accommodation_id
        WHERE rt.accommodation_id = #{accommodationId}
          AND rt.status = 'ACTIVE'
          AND a.status = 'ACTIVE'
        ORDER BY rt.name ASC, rt.room_type_id ASC
    </select>

    <select id="findPricePolicies" resultMap="OpsPricePolicyRecordMap">
        SELECT
            pp.policy_id,
            a.accommodation_id,
            a.name AS accommodation_name,
            pp.room_type_id,
            rt.name AS room_type_name,
            pp.policy_name,
            pp.start_date,
            pp.end_date,
            pp.delta_amount,
            pp.day_of_week_mask,
            pp.status,
            pp.created_at
        FROM price_policies pp
        JOIN room_types rt
            ON rt.room_type_id = pp.room_type_id
        JOIN accommodations a
            ON a.accommodation_id = pp.accommodation_id
        WHERE (#{isAdmin} = TRUE OR a.host_user_id = #{hostUserId})
          AND (
              #{accommodationId} IS NULL
              OR a.accommodation_id = #{accommodationId}
          )
          AND (
              #{roomTypeId} IS NULL
              OR pp.room_type_id = #{roomTypeId}
          )
        ORDER BY pp.start_date ASC, pp.end_date ASC, pp.policy_id ASC
    </select>

    <select id="lockRoomTypeTarget" resultMap="OpsPricingRoomTypeTargetRecordMap">
        SELECT
            rt.room_type_id,
            rt.accommodation_id,
            a.name AS accommodation_name,
            rt.name AS room_type_name,
            rt.base_price,
            rt.status AS room_type_status,
            a.host_user_id
        FROM room_types rt
        JOIN accommodations a
            ON a.accommodation_id = rt.accommodation_id
        WHERE rt.room_type_id = #{roomTypeId}
        FOR UPDATE
    </select>

    <select id="lockPricePolicyTarget" resultMap="OpsPricePolicyMutationTargetRecordMap">
        SELECT
            pp.policy_id,
            pp.accommodation_id,
            a.name AS accommodation_name,
            pp.room_type_id,
            rt.name AS room_type_name,
            a.host_user_id,
            pp.policy_name,
            pp.start_date,
            pp.end_date,
            pp.delta_amount,
            pp.day_of_week_mask,
            pp.status
        FROM price_policies pp
        JOIN room_types rt
            ON rt.room_type_id = pp.room_type_id
        JOIN accommodations a
            ON a.accommodation_id = pp.accommodation_id
        WHERE pp.policy_id = #{policyId}
        FOR UPDATE
    </select>

    <select id="findActivePricePoliciesByAccommodationIdsForDateRange" resultMap="ActivePricePolicyRecordMap">
        SELECT
            pp.policy_id,
            pp.room_type_id,
            rt.name AS room_type_name,
            pp.policy_name,
            pp.start_date,
            pp.end_date,
            pp.delta_amount,
            pp.day_of_week_mask
        FROM price_policies pp
        JOIN room_types rt
            ON rt.room_type_id = pp.room_type_id
        WHERE pp.accommodation_id IN
        <foreach collection="accommodationIds" item="accommodationId" open="(" separator="," close=")">
            #{accommodationId}
        </foreach>
          AND pp.status = 'ACTIVE'
          AND pp.start_date &lt; #{endDate}
          AND pp.end_date &gt;= #{startDate}
        ORDER BY pp.start_date ASC, pp.end_date ASC, pp.policy_id ASC
    </select>
</mapper>
